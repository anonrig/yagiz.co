<form class="grid grid-cols-canvas [&>*]:col-main gap-y-4 mt-6">
  <div
    id='success-message'
    role="status"
    class="bg-[#f6f6f6] dark:bg-[#2f333c] text-neutral-600 dark:text-neutral-200 px-4 sm:px-6 py-2 rounded-md text-sm flex flex-col sm:flex-row sm:gap-x-2 hidden"
  >
    <div class="font-extrabold">Subscribed successfully.</div>
    Thank you for signing up. You will receive an email shortly.
  </div>

  <div
    id='error-message'
    role="alert"
    class="text-red-600 dark:text-red-400 text-sm hidden"
  ></div>

  <div class="flex flex-col gap-y-2">
    <label for='name' class="block text-black dark:text-white font-bold">
      Name:
    </label>
    <input
      id='name'
      name='name'
      autocapitalize='off'
      autocorrect='off'
      autocomplete='name'
      required
      type="text"
      minlength={2}
      placeholder="What is your name?"
      class="font-normal bg-white dark:bg-white-reversed border-[1px] border-slate-200 dark:border-neutral-600 border-solid leading-[1.15] rounded-md text-slate-800 dark:text-white h-[44px] px-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400 focus-visible:ring-offset-2"
    />
  </div>

  <div class="flex flex-col gap-y-2">
    <label for='email' class="block text-black dark:text-white font-bold">
      Email Address:
    </label>
    <input
      id='email'
      name='email'
      autocapitalize='off'
      autocorrect='off'
      autocomplete='email'
      required
      type="email"
      minlength={6}
      placeholder="What is your email?"
      class="font-normal bg-white dark:bg-white-reversed border-[1px] border-slate-200 dark:border-neutral-600 border-solid leading-[1.15] rounded-md text-slate-800 dark:text-white h-[44px] px-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400 focus-visible:ring-offset-2"
    />
  </div>

  <div>
    <button
      id='submit'
      type="submit"
      class="disabled:opacity-60 disabled:cursor-not-allowed uppercase mt-2 items-center bg-white dark:bg-white-reversed border-[1px] border-slate-200 dark:border-neutral-600 hover:border-slate-300 dark:hover:border-neutral-500 border-solid rounded-md text-orange-400 text-[11px] font-extrabold h-[36px] justify-center tracking-[0.5px] px-[15px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400 focus-visible:ring-offset-2"
    >
      Sign up
    </button>
  </div>
</form>

<script>
  const form: HTMLFormElement = document.querySelector('form')!
  const submit: HTMLButtonElement = document.querySelector('#submit')!
  const name: HTMLInputElement = document.querySelector('#name')!
  const email: HTMLInputElement = document.querySelector('#email')!
  const successMessage: HTMLDivElement = document.querySelector('#success-message')!
  const errorMessage: HTMLDivElement = document.querySelector('#error-message')!

  form.addEventListener('submit', async (event) => {
    event.preventDefault()
    submit.disabled = true
    errorMessage.classList.add('hidden')
    errorMessage.textContent = ''

    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email: email.value, name: name.value }),
      })

      if (!res.ok) {
        const { message: msg } = await res.json() as { message: string }
        throw new Error(msg)
      }

      successMessage.classList.remove('hidden')
      email.value = ''
      name.value = ''
    } catch (error) {
      if (error instanceof Error) {
        errorMessage.textContent = error.message || 'Something went wrong. Please try again.'
      } else {
        errorMessage.textContent = 'Something went wrong. Please try again.'
      }
      errorMessage.classList.remove('hidden')
      successMessage.classList.add('hidden')
    }

    submit.disabled = false
  })
</script>
